@baseUrl = https://localhost:7050

### ===== СТАТУСЫ (только чтение) =====

### Получить все статусы маршрутных листов
GET {{baseUrl}}/api/RoutingSheetStatuses

### Получить статус МЛ по ID
GET {{baseUrl}}/api/RoutingSheetStatuses/1

### Получить все статусы операций
GET {{baseUrl}}/api/OperationStatuses

### Получить статус операции по ID
GET {{baseUrl}}/api/OperationStatuses/1


### ===== ЕДИНИЦЫ ИЗМЕРЕНИЯ =====

### Получить все единицы измерения
GET {{baseUrl}}/api/Units

### Получить единицу измерения по ID
GET {{baseUrl}}/api/Units/1

### Создать единицу измерения
POST {{baseUrl}}/api/Units
Content-Type: application/json

{
  "name": "шт."
}

### Обновить единицу измерения
PUT {{baseUrl}}/api/Units/1
Content-Type: application/json

{
  "name": "штуки"
}

### Удалить единицу измерения
DELETE {{baseUrl}}/api/Units/1


### ===== ЦЕХА =====

### Получить все цеха
GET {{baseUrl}}/api/Guilds

### Получить цех по ID
GET {{baseUrl}}/api/Guilds/1

### Создать цех
POST {{baseUrl}}/api/Guilds
Content-Type: application/json

{
  "name": "Сборочный цех №1"
}

### Обновить цех
PUT {{baseUrl}}/api/Guilds/1
Content-Type: application/json

{
  "name": "Сборочный цех №2"
}

### Удалить цех
DELETE {{baseUrl}}/api/Guilds/1


### ===== ИСПОЛНИТЕЛИ =====

### Получить всех исполнителей
GET {{baseUrl}}/api/Performers

### Создать исполнителя
POST {{baseUrl}}/api/Performers
Content-Type: application/json

{
  "fullName": "Иванов Иван Иванович",
  "role": "Слесарь"
}

### Обновить исполнителя
PUT {{baseUrl}}/api/Performers/1
Content-Type: application/json

{
  "fullName": "Петров Петр Петрович",
  "role": "Сварщик"
}


### ===== ИЗДЕЛИЯ (только чтение) =====

### Получить все изделия
GET {{baseUrl}}/api/ProductItems

### Получить изделие по ID
GET {{baseUrl}}/api/ProductItems/1


### ===== ПОЗИЦИИ ПЛАНА ПРОИЗВОДСТВА =====

### Получить все позиции плана
GET {{baseUrl}}/api/PlanPositions

### Получить позицию плана по ID
GET {{baseUrl}}/api/PlanPositions/1

### Создать позицию плана
POST {{baseUrl}}/api/PlanPositions
Content-Type: application/json

{
  "positionCode": "PP-2024-001",
  "name": "План на январь - Деталь А",
  "productItemId": 1,
  "quantityPlanned": 100
}

### Обновить позицию плана
PUT {{baseUrl}}/api/PlanPositions/1
Content-Type: application/json

{
  "positionCode": "PP-2024-001",
  "name": "План на январь - Деталь А (обновлено)",
  "productItemId": 1,
  "quantityPlanned": 150
}


### ===== МАРШРУТНЫЕ ЛИСТЫ =====

### Получить все маршрутные листы
GET {{baseUrl}}/api/RoutingSheets

### Получить МЛ с фильтром по позиции плана
GET {{baseUrl}}/api/RoutingSheets?planPositionId=1

### Получить МЛ с фильтром по изделию
GET {{baseUrl}}/api/RoutingSheets?productItemId=1

### Получить маршрутный лист по ID (с операциями)
GET {{baseUrl}}/api/RoutingSheets/1

### Изменить статус МЛ (1=Черновик, 2=Активен, 3=Завершен, 4=Отменен)
PATCH {{baseUrl}}/api/RoutingSheets/1/status
Content-Type: application/json

{
  "statusId": 2
}

### Разбить маршрутный лист
POST {{baseUrl}}/api/RoutingSheets/1/split
Content-Type: application/json

{
  "operationIds": [1, 2],
  "newNumber": "МЛ-001-SPLIT",
  "newName": "Новый МЛ после разбиения",
  "newQuantity": 25
}

### Удалить маршрутный лист
DELETE {{baseUrl}}/api/RoutingSheets/1


### ===== ОПЕРАЦИИ =====

### Получить все операции
GET {{baseUrl}}/api/Operations

### Получить операции по маршрутному листу
GET {{baseUrl}}/api/Operations?routingSheetId=1

### Получить операции по маршрутному листу (альтернативный путь)
GET {{baseUrl}}/api/Operations/by-routing-sheet/1

### Получить операции по цеху
GET {{baseUrl}}/api/Operations?guildId=1

### Получить операции по цеху (альтернативный путь)
GET {{baseUrl}}/api/Operations/by-guild/1

### Получить операцию по ID
GET {{baseUrl}}/api/Operations/1

### Назначить исполнителя на операцию
PATCH {{baseUrl}}/api/Operations/1/assign-performer
Content-Type: application/json

{
  "performerId": 1
}

### Снять исполнителя с операции
DELETE {{baseUrl}}/api/Operations/1/performer

### Изменить статус операции
PATCH {{baseUrl}}/api/Operations/1/status
Content-Type: application/json

{
  "statusId": 3
}

### Удалить операцию
DELETE {{baseUrl}}/api/Operations/1
